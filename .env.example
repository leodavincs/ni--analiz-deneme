# Niş Avcısı — ortam değişkenleri örneği.
# Bu dosyayı `.env` olarak kopyalayıp kendi değerlerinle doldur.
# `.env` git'e EKLENMEZ (.gitignore'da).

# Apify token — reddit_apify collector için. Ücretsiz: https://apify.com
APIFY_TOKEN=

# Reddit OAuth (opsiyonel — public API yerine sağlam erişim için)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Web paneli portu (opsiyonel — varsayılan 8000)
PORT=8000
